ient","import RichTextView","","struct ArticleBody: View {","    let content: RichText<Content>","","    var body: some View {","        ScrollView {","            content","                .padding()","        }","    }","}"]},{"type":"heading","level":2,"text":"Built-in rendering","anchor":"Built-in-rendering"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each node type renders with a default view designed to look reasonable out of the box:"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Node","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Default rendering"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Document","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"LazyVStack"},{"text":" of its child nodes.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Paragraph","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"Text"},{"text":" with inline marks; a lone image paragraph renders as the image.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Heading"}],"type":"paragraph"}],[{"inlineContent":[{"code":"Text","type":"codeVoice"},{"type":"text","text":" sized by heading level ("},{"code":"largeTitle","type":"codeVoice"},{"type":"text","text":" … "},{"code":"subheadline","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Text","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"An "},{"type":"codeVoice","code":"AttributedString"},{"type":"text","text":" carrying its inline marks."}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Bullet \/ Ordered list","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Indented rows with depth-aware bullets or numbers.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Blockquote"}],"type":"paragraph"}],[{"inlineContent":[{"text":"A leading accent bar beside the quoted content.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Code block","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Monospaced ","type":"text"},{"code":"Text","type":"codeVoice"},{"text":" on a rounded, tinted background.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Image"}],"type":"paragraph"}],[{"inlineContent":[{"code":"AsyncImage","type":"codeVoice"},{"type":"text","text":" with loading and failure placeholders."}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Table"}],"type":"paragraph"}],[{"inlineContent":[{"text":"A ","type":"text"},{"code":"Grid","type":"codeVoice"},{"text":" with header and cell styling, honoring column spans.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Embedded blok"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"The component rendered through your block library’s "},{"code":"View","type":"codeVoice"},{"type":"text","text":" conformance."}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Emoji"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"The emoji character."}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Horizontal rule","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"A "},{"code":"Divider","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Hard break","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"A line break.","type":"text"}],"type":"paragraph"}]]]},{"type":"heading","level":3,"text":"Inline marks","anchor":"Inline-marks"},{"type":"paragraph","inlineContent":[{"text":"Formatting marks on a text run — bold, italic, underline, strikethrough, inline code, subscript, superscript, links, and text\/highlight colors — are accumulated and applied together into a single ","type":"text"},{"code":"AttributedString","type":"codeVoice"},{"text":". Color marks (","type":"text"},{"code":"textStyle","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"highlight","type":"codeVoice"},{"text":") are parsed from CSS color values. Unknown marks are ignored.","type":"text"}]},{"type":"heading","level":2,"text":"Customizing node rendering","anchor":"Customizing-node-rendering"},{"type":"paragraph","inlineContent":[{"text":"To override how specific node types render, conform a type to ","type":"text"},{"identifier":"doc:\/\/RichTextView\/documentation\/RichTextView\/RichTextViewDelegate","isActive":true,"type":"reference"},{"text":" and install it with ","type":"text"},{"identifier":"doc:\/\/RichTextView\/documentation\/RichTextView\/SwiftUICore\/View\/richTextViewDelegate(_:)","isActive":true,"type":"reference"},{"text":". Every requirement has a default implementation matching the built-in renderer, so you implement only the node types you want to change:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct MyDelegate: RichTextViewDelegate {","    typealias BlockLibrary = Content","","    @MainActor","    func view(for heading: RichText<Content>.Heading) -> any View {","        Text(heading.attributedString())","            .font(.system(.title, design: .serif))","    }","","    @MainActor","    func view(for codeBlock: RichText<Content>.CodeBlock) -> any View {","        MySyntaxHighlightedCode(codeBlock)","    }","}","","ScrollView { article.content }","    .richTextViewDelegate(MyDelegate())"]},{"type":"paragraph","inlineContent":[{"text":"The delegate’s ","type":"text"},{"type":"codeVoice","code":"BlockLibrary"},{"text":" associated type must match the rich text being rendered. The delegate applies to all rich text in the view hierarchy below the modifier; node types it does not implement keep their defaults.","type":"text"}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Inline marks and unknown no